generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id          Int      @id @default(autoincrement())
  razonSocial String
  ruc         String   @unique
  direccion   String?
  telefono    String?
  correo      String?
  logo        String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sucursales Sucursal[]
}

model Sucursal {
  id        Int     @id @default(autoincrement())
  nombre    String
  direccion String?
  telefono  String?
  activo    Boolean @default(true)

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  usuarios Usuario[]
}

model Rol {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  usuarios Usuario[]
}

model Usuario {
  id           Int    @id @default(autoincrement())
  nombres      String
  apellidos    String
  email        String @unique
  passwordHash String

  activo Boolean @default(true)

  rolId Int
  rol   Rol @relation(fields: [rolId], references: [id])

  sucursalId Int
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Auditoria {
  id Int @id @default(autoincrement())

  usuarioId Int?
  accion    String
  modulo    String

  descripcion String?

  fecha DateTime @default(now())
}

model Categoria {
  id Int @id @default(autoincrement())

  codigo String @unique

  nombre      String  @unique
  descripcion String?
  estado      Boolean @default(true)

  productos Producto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UnidadMedida {
  id Int @id @default(autoincrement())

  codigoSistema String? @unique

  codigo String @unique
  nombre String

  estado Boolean @default(true)

  productos Producto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Producto {
  id Int @id @default(autoincrement())

  codigoSistema String? @unique

  codigo String @unique

  nombre String

  descripcion String?

  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  unidadMedidaId Int
  unidadMedida   UnidadMedida @relation(fields: [unidadMedidaId], references: [id])

  stockActual Decimal @default(0)

  stockMinimo Decimal @default(0)

  costo Decimal @default(0)

  precioVenta Decimal @default(0)

  estado Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  StockAlmacen         StockAlmacen[]
  MovimientoInventario MovimientoInventario[]

  detallesCompra DetalleCompra[]
}

model Almacen {
  id Int @id @default(autoincrement())

  codigoSistema String? @unique

  codigo String @unique

  nombre String

  ubicacion   String?
  responsable String?

  estado Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks      StockAlmacen[]
  movimientos MovimientoInventario[]

  compras Compra[]
}

model StockAlmacen {
  id Int @id @default(autoincrement())

  productoId Int
  almacenId  Int

  stockActual Decimal @default(0)

  producto Producto @relation(fields: [productoId], references: [id])
  almacen  Almacen  @relation(fields: [almacenId], references: [id])

  @@unique([productoId, almacenId])
}

model MovimientoInventario {
  id Int @id @default(autoincrement())

  fecha DateTime @default(now())

  tipo String

  cantidad Decimal

  observacion String?

  productoId Int
  almacenId  Int

  producto Producto @relation(fields: [productoId], references: [id])
  almacen  Almacen  @relation(fields: [almacenId], references: [id])
}

model Proveedor {
  id Int @id @default(autoincrement())

  codigoSistema String? @unique

  ruc String @unique

  razonSocial String

  direccion String?
  telefono  String?
  correo    String?
  contacto  String?

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compras Compra[]
}

model Compra {
  id Int @id @default(autoincrement())

  codigoSistema String? @unique

  fecha DateTime @default(now())

  tipoDocumento String

  numeroDocumento String

  estado String @default("PENDIENTE")

  observacion String?

  archivoAdjunto String?

  subtotal Decimal @default(0)

  igv Decimal @default(0)

  total Decimal @default(0)

  proveedorId Int
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])

  almacenId Int
  almacen   Almacen @relation(fields: [almacenId], references: [id])

  detalles DetalleCompra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DetalleCompra {
  id Int @id @default(autoincrement())

  compraId Int
  compra   Compra @relation(fields: [compraId], references: [id])

  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  cantidad Decimal

  precioUnitario Decimal

  subtotal Decimal
}
